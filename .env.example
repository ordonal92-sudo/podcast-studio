# ─── Required ─────────────────────────────────────────────────────────────────

# Password to log in to your podcast dashboard
ADMIN_PASSWORD=your-strong-password-here

# Secret key for session tokens (generate a random 32+ char string)
JWT_SECRET=change-this-to-a-random-secret-string-32chars

# Your podcast's public URL (no trailing slash)
# For local dev: http://localhost:3000
# For production: https://yourpodcast.com
PODCAST_BASE_URL=http://localhost:3000

# ─── Podcast Info ──────────────────────────────────────────────────────────────
PODCAST_TITLE=My Podcast
PODCAST_DESCRIPTION=A great podcast about...
PODCAST_AUTHOR=Your Name
PODCAST_EMAIL=your@email.com

# ─── YouTube (optional) ────────────────────────────────────────────────────────
# Step 1: Go to https://console.cloud.google.com
# Step 2: Create a project → Enable "YouTube Data API v3"
# Step 3: Create OAuth 2.0 credentials (Desktop App or Web App)
# Step 4: Set redirect URI to: http://localhost:3000/api/youtube/callback
# Step 5: Fill in CLIENT_ID and CLIENT_SECRET, then visit /api/youtube/auth
# Step 6: After auth, copy the REFRESH_TOKEN shown on screen into this file

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/youtube/callback
YOUTUBE_REFRESH_TOKEN=
